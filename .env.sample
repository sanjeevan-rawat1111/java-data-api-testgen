# Copy to .env:  cp .env.sample .env

# ── LLM (FREE option — Google Gemini via AI Studio) ───────────────────────────
# Get a free key in 2 minutes at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=paste-your-google-ai-studio-key-here
# base_url is already set in config.yaml — nothing else needed for LLM

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=mydatabase
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword
MYSQL_EXPOSED_PORT=3307

# ── Aerospike ─────────────────────────────────────────────────────────────────
AERO_NAMESPACE=test
AERO_EXPOSED_PORT=3004

# ── Application (SUT) ─────────────────────────────────────────────────────────
APP_EXPOSED_PORT=8080

# ── Flask helper ──────────────────────────────────────────────────────────────
HELPER_EXPOSED_PORT=5000
LOG_LEVEL=INFO
